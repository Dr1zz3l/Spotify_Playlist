# Copy this file to ".env" and fill in the values from your Spotify Developer app
# Dashboard: https://developer.spotify.com/dashboard  ->  Create app  ->  Settings
SPOTIPY_CLIENT_ID=your_client_id_here
SPOTIPY_CLIENT_SECRET=your_client_secret_here
# Must EXACTLY match a Redirect URI registered in the app settings:
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8888/callback
